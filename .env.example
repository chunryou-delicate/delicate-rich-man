# 이 파일을 복사해서 .env 로 저장한 뒤 실제 키를 채우세요.
#   cp .env.example .env
# .env 는 .gitignore 되어 깃에 올라가지 않습니다 (키 유출 방지).

# DART OpenAPI 인증키 (필수) — https://opendart.fss.or.kr 에서 무료 발급
DART_API_KEY=

# KRX Data Marketplace 로그인 (시세·시가총액·PER·PBR 조회용, 무료 회원가입)
#   data.krx.co.kr 자체 아이디/비밀번호 (네이버·카카오 간편가입 말고 KRX 자체 계정)
#   pykrx 가 이 값으로 로그인해 시세를 받아옵니다.
KRX_ID=
KRX_PW=

# KIS(한국투자증권) API — 실제 주문 실행(실전 매매) 단계에서만 필요. 지금은 비워둠.
KIS_APP_KEY=
KIS_APP_SECRET=
